{
  "name": "automation-os",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx scripts/build-code-graph.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "code-graph:rebuild": "tsx scripts/build-code-graph.ts --rebuild",
    "code-graph:watch": "tsx scripts/build-code-graph.ts --watch-only",
    "code-graph:health": "tsx scripts/code-graph-health-check.ts",
    "dev:server": "node --watch --watch-path=server --watch-path=shared --import tsx/esm server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:drizzle-legacy": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "seed:production": "tsx scripts/seed.ts --production",
    "skills:apply-visibility": "tsx scripts/apply-skill-visibility.ts",
    "skills:verify-visibility": "tsx scripts/verify-skill-visibility.ts",
    "skills:backfill": "tsx scripts/backfill-system-skills.ts",
    "playbooks:validate": "tsx scripts/validate-playbooks.ts",
    "playbooks:test": "tsx server/lib/workflow/__tests__/workflow.test.ts",
    "test": "npm run test:gates && npm run test:qa && npm run test:unit",
    "verify:rls": "bash scripts/verify-rls-coverage.sh && bash scripts/verify-rls-contract-compliance.sh && bash scripts/verify-rls-session-var-canon.sh",
    "test:gates": "bash scripts/run-all-gates.sh",
    "test:qa": "bash scripts/run-all-qa-tests.sh",
    "test:unit": "vitest run",
    "test:trajectories": "tsx scripts/run-trajectory-tests.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.515.0",
    "@aws-sdk/s3-request-presigner": "^3.515.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@playwright/test": "^1.59.1",
    "@sendgrid/mail": "^8.1.0",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/diff": "^7.0.2",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.2",
    "langfuse": "^3.38.6",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "p-limit": "^7.3.0",
    "pg-boss": "^9.0.3",
    "playwright": "^1.59.1",
    "postgres": "^3.4.4",
    "proper-lockfile": "^4.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "resend": "^6.9.2",
    "rrule": "^2.8.1",
    "sanitize-html": "^2.17.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "ts-morph": "~28.0.0",
    "turndown": "^7.2.4",
    "uuid": "^9.0.1",
    "wink-bm25-text-search": "^3.1.2",
    "yaml": "^2.8.3",
    "yauzl": "^3.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^9.0.7",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
