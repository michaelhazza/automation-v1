+                  ? <span className="text-indigo-500">{listSort.dir === 'asc' ? '↑' : '↓'}</span>
+                  : <span className="text-slate-300">↕</span>}
+              </span>
+            </th>
+          ))}
+          <th className="whitespace-nowrap">Reports To</th>
+        </tr>
+      </thead>
+      <tbody>
+        {listAgents.map((a: any) => {
