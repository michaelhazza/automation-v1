+      )}
+      <span className="ml-auto text-[12px] text-slate-400">{listAgents.length} agent{listAgents.length !== 1 ? 's' : ''}</span>
+    </div>
+    <table className="data-table w-full">
+      <thead>
+        <tr>
+          {([
+            { col: 'name' as const, label: 'Name' },
