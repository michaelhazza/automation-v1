{
  "name": "@dev-tools/mission-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only 'What's In Flight' dashboard. Self-contained, portable across projects via env-var config.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
