# Mission Control — env-driven configuration
#
# All paths are evaluated relative to MISSION_CONTROL_REPO_ROOT, which defaults
# to the directory the dashboard server is started from. Override any value to
# port this dashboard to a different repo.

# Filesystem root the dashboard reads logs and build progress from.
# Default: process.cwd() (the dir you run the dashboard from)
# MISSION_CONTROL_REPO_ROOT=/path/to/your/project

# Port the dashboard server binds to (127.0.0.1 only, never exposed externally).
# Default: 5050
# MISSION_CONTROL_PORT=5050

# Port the Vite client dev server binds to.
# Default: 5051
# MISSION_CONTROL_CLIENT_PORT=5051

# GitHub repo the dashboard queries for PRs and CI status. Format: <owner>/<name>
# Default: inferred from `git remote get-url origin`
# MISSION_CONTROL_GITHUB_REPO=michaelhazza/automation-v1

# GitHub personal-access token (read-only PR + actions scopes are sufficient).
# Required for the /api/github/* endpoints to return non-empty data.
# GITHUB_TOKEN=ghp_xxxxx
