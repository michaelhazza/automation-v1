{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "ES2021", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist",
    "rootDir": "..",
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx"
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}
