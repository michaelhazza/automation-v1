# Automation OS - Environment Configuration
# Copy this file to .env and fill in the values

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/automation_os

# Required: JWT secret (minimum 256-bit entropy, generate with: openssl rand -base64 32)
JWT_SECRET=your-256-bit-secret-here-use-openssl-rand-base64-32

# Required: Sender email address for all outgoing emails
EMAIL_FROM=noreply@youragency.com

# Optional: HTTP port the server listens on (default: 3000)
PORT=3000

# Optional: Node.js environment mode (default: development)
NODE_ENV=development

# Optional: File storage backend (default: r2, allowed: r2, s3)
FILE_STORAGE_BACKEND=r2

# Conditional (required if FILE_STORAGE_BACKEND=r2): Cloudflare R2 credentials
R2_ACCOUNT_ID=abc123def456ghi789
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=automation-os-files

# Conditional (required if FILE_STORAGE_BACKEND=s3): AWS S3 credentials
S3_REGION=ap-southeast-2
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=automation-os-files

# Optional: Email delivery provider (default: sendgrid, allowed: sendgrid, smtp, resend)
EMAIL_PROVIDER=resend

# Conditional (required if EMAIL_PROVIDER=resend): Resend API key
RESEND_API_KEY=re_your-resend-api-key-here

# Conditional (required if EMAIL_PROVIDER=sendgrid): SendGrid API key
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Conditional (required if EMAIL_PROVIDER=smtp): SMTP server settings
SMTP_HOST=smtp.mailserver.com
SMTP_PORT=587
SMTP_USER=smtp-username@yourdomain.com
SMTP_PASS=your-smtp-password

# Optional: Background job queue backend (default: pg-boss, allowed: pg-boss, bullmq)
JOB_QUEUE_BACKEND=pg-boss

# Conditional (required if JOB_QUEUE_BACKEND=bullmq): Redis connection string
REDIS_URL=redis://localhost:6379

# Optional: Number of concurrent queue workers (default: 5)
QUEUE_CONCURRENCY=5

# Webhook return URL configuration
# The publicly reachable root URL of this server. The platform appends the
# per-execution callback path automatically so you never need to configure
# return URLs per task or per external engine.
# Example: https://myapp.example.com  (no trailing slash)
WEBHOOK_BASE_URL=https://app.youragency.com

# Optional: HMAC secret used to sign and verify webhook callback tokens.
# Set this to a long random string in production (openssl rand -base64 32).
# When set, the platform appends ?token=<hmac> to every return URL and
# rejects incoming callbacks whose token doesn't match.
WEBHOOK_SECRET=your-webhook-hmac-secret-here

# Optional: File retention period in days (default: 30)
FILE_RETENTION_DAYS=30

# Optional: Default execution timeout in seconds (default: 300)
EXECUTION_TIMEOUT_DEFAULT_SECONDS=300

# Optional: Application log verbosity (default: info, allowed: error, warn, info, debug)
LOG_LEVEL=info

# Optional: Allowed CORS origins (default: *)
CORS_ORIGINS=https://app.youragency.com

# Optional: Invite token expiry in hours (default: 72)
INVITE_TOKEN_EXPIRY_HOURS=72

# Optional: Password reset token expiry in hours (default: 1)
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Optional: Application base URL used in email links (default: http://localhost:5173)
APP_BASE_URL=https://app.youragency.com
