# Automation OS - Environment Configuration
# Copy this file to .env and fill in the values

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/automation_os

# Required: JWT secret (minimum 256-bit entropy, generate with: openssl rand -base64 32)
JWT_SECRET=your-256-bit-secret-here-use-openssl-rand-base64-32

# Required: Sender email address for all outgoing emails
EMAIL_FROM=noreply@youragency.com

# Optional: HTTP port the server listens on (default: 3000)
PORT=3000

# Optional: Node.js environment mode (default: development)
NODE_ENV=development

# Optional: File storage backend (default: r2, allowed: r2, s3)
FILE_STORAGE_BACKEND=r2

# Conditional (required if FILE_STORAGE_BACKEND=r2): Cloudflare R2 credentials
R2_ACCOUNT_ID=abc123def456ghi789
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=automation-os-files

# Conditional (required if FILE_STORAGE_BACKEND=s3): AWS S3 credentials
S3_REGION=ap-southeast-2
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=automation-os-files

# Optional: Email delivery provider (default: sendgrid, allowed: sendgrid, smtp, resend)
EMAIL_PROVIDER=resend

# Conditional (required if EMAIL_PROVIDER=resend): Resend API key
RESEND_API_KEY=re_your-resend-api-key-here

# Conditional (required if EMAIL_PROVIDER=sendgrid): SendGrid API key
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Conditional (required if EMAIL_PROVIDER=smtp): SMTP server settings
SMTP_HOST=smtp.mailserver.com
SMTP_PORT=587
SMTP_USER=smtp-username@yourdomain.com
SMTP_PASS=your-smtp-password

# Optional: Background job queue backend (default: pg-boss, allowed: pg-boss, bullmq)
JOB_QUEUE_BACKEND=pg-boss

# Conditional (required if JOB_QUEUE_BACKEND=bullmq): Redis connection string
REDIS_URL=redis://localhost:6379

# Optional: Number of concurrent queue workers (default: 5)
QUEUE_CONCURRENCY=5

# Webhook return URL configuration
# The publicly reachable root URL of this server. The platform appends the
# per-execution callback path automatically so you never need to configure
# return URLs per task or per external engine.
# Example: https://myapp.example.com  (no trailing slash)
WEBHOOK_BASE_URL=https://app.youragency.com

# Optional: HMAC secret used to sign and verify webhook callback tokens.
# Set this to a long random string in production (openssl rand -base64 32).
# When set, the platform appends ?token=<hmac> to every return URL and
# rejects incoming callbacks whose token doesn't match.
WEBHOOK_SECRET=your-webhook-hmac-secret-here

# Required in production: HMAC secret for signing clientpulse pagination cursors.
# When absent the server falls back to a per-org deterministic seed (safe for dev,
# not a production secret). Generate with: openssl rand -base64 32
PULSE_CURSOR_SECRET=your-pulse-cursor-secret-here

# Optional: File retention period in days (default: 30)
FILE_RETENTION_DAYS=30

# Optional: Default execution timeout in seconds (default: 300)
EXECUTION_TIMEOUT_DEFAULT_SECONDS=300

# Optional: Application log verbosity (default: info, allowed: error, warn, info, debug)
LOG_LEVEL=info

# Optional: Allowed CORS origins (default: *)
CORS_ORIGINS=https://app.youragency.com

# Optional: Invite token expiry in hours (default: 72)
INVITE_TOKEN_EXPIRY_HOURS=72

# Optional: Password reset token expiry in hours (default: 1)
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Optional: Application base URL used in email links (default: http://localhost:5173)
APP_BASE_URL=https://app.youragency.com

# Optional: OpenAI API key — required for vector memory search (Phase 2A)
# Used exclusively for text-embedding-3-small embeddings. Gracefully degrades if unset.
OPENAI_API_KEY=sk-your-openai-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# IEE — Integrated Execution Environment (rev 7)
# Spec: docs/iee-development-spec.md
#
# These variables are read by:
#   • the main app (server/services/ieeExecutionService.ts) for enqueue-time
#     estimates and the reservation TTL
#   • the worker process (worker/src/config/env.ts) for the runtime loop
# Both processes must see consistent values for the cost / reservation /
# heartbeat invariants to hold.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server-side IEE knobs ──────────────────────────────────────────────────

# Conservative cost estimate (cents) per LLM step at enqueue time. Used by
# ieeExecutionService.estimateIeeCostCents(). Better to over-reserve and
# reject a job than to under-reserve and overspend.
IEE_AVG_LLM_COST_CENTS_PER_STEP=5

# Flat per-run cost (cents) added to the estimate to amortise baseline VPS
# overhead.
IEE_FLAT_RUNTIME_COST_CENTS=20

# Maximum loop steps used in the enqueue-time cost estimate. The worker
# enforces this same value at runtime via MAX_STEPS_PER_EXECUTION.
IEE_MAX_STEPS=25

# Reservation TTL in minutes. The cleanup job (iee-cleanup-orphans) sweeps
# any pending+reserved row older than this and releases the reservation.
# Spec §13.6.1.a — must be > pg-boss expireInSeconds for iee-*-task (10 min).
IEE_RESERVATION_TTL_MINUTES=15

# ── Worker-side IEE knobs ──────────────────────────────────────────────────
# Used ONLY by the worker process. The main app does not read these.

# Where Playwright persistent browser sessions live. In Docker this maps to
# the worker_sessions named volume. Sessions are namespaced
# per-organisation/subaccount/sessionKey to prevent cross-tenant access.
BROWSER_SESSION_DIR=/var/browser-sessions

# Base directory for ephemeral dev workspaces. Each iee_run gets its own
# subdir, destroyed at the end of the job (success or failure).
WORKSPACE_BASE_DIR=/tmp/workspaces

# Loop limits — see worker spec §4.5.
MAX_STEPS_PER_EXECUTION=25
MAX_EXECUTION_TIME_MS=300000
MAX_COMMAND_TIME_MS=30000

# pg-boss polling + concurrency. With Playwright at 1 browser/worker the
# default of 1 browser + 2 dev jobs in flight is safe on a 4 GB VPS.
WORKER_POLL_INTERVAL_MS=1000
IEE_BROWSER_CONCURRENCY=1
IEE_DEV_CONCURRENCY=2

# Heartbeat (§13.3 / §13.6.1.b). The worker writes lastHeartbeatAt every
# IEE_HEARTBEAT_INTERVAL_MS while a job is running. The reconciliation scan
# at boot fails any 'running' row whose heartbeat is older than this AND
# whose workerInstanceId is not the current worker.
IEE_HEARTBEAT_INTERVAL_MS=10000
IEE_HEARTBEAT_DEAD_AFTER_S=60

# Runtime cost pricing (§11.3.4). Defaults to 0 in dev so local test runs
# never pollute reporting with fake cost. Set non-zero values on the
# DigitalOcean VPS to attribute compute time per run. Suggested production
# values for a 4 GB / 2 vCPU droplet:
#   IEE_COST_CPU_USD_PER_SEC=0.00002
#   IEE_COST_MEM_USD_PER_GB_HR=0.04
#   IEE_COST_FLAT_USD_PER_RUN=0.001
IEE_COST_CPU_USD_PER_SEC=0
IEE_COST_MEM_USD_PER_GB_HR=0
IEE_COST_FLAT_USD_PER_RUN=0

# Browser session corruption recovery (§13.6). After IEE_SESSION_TTL_DAYS,
# stale sessions are reported by the cleanup job. By default they are NOT
# auto-pruned (losing an authenticated session has user-visible
# consequences). Set IEE_SESSION_AUTO_PRUNE=true to opt in to deletion.
IEE_SESSION_TTL_DAYS=30
IEE_SESSION_AUTO_PRUNE=false

# Git author identity for git_commit actions inside dev tasks (§7.6).
IEE_GIT_AUTHOR_NAME="AutomationOS IEE"
IEE_GIT_AUTHOR_EMAIL=iee@automation-os.local

# Anti-stagnation rule (§13.4). The number of consecutive no-progress steps
# before the LLM is told to either change strategy or call `failed`. This is
# a prompt-only nudge, not a hard constraint.
IEE_NO_PROGRESS_THRESHOLD=3

# How often the worker emits an iee.queue.depth structured log line
# (waiting / active / oldest wait age per IEE queue). Reviewer round 4 #5.
# Single grep target for SREs spotting queue saturation. Cheap; one SQL
# query per interval, no dashboard required.
IEE_QUEUE_METRICS_INTERVAL_MS=60000

# ── Worker container resource limits (reviewer round 2) ────────────────────
# Read by docker-compose.yml. Conservative defaults — adjust per env on the
# production VPS. Not a sandbox; just a runaway protection ceiling.
IEE_WORKER_MEM_LIMIT=3g
IEE_WORKER_MEM_RESERVATION=1g
IEE_WORKER_CPUS=2

# Lead discovery (SDR Agent)
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=
