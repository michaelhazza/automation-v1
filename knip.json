{
  "$schema": "node_modules/knip/schema.json",
  "entry": [
    "server/index.ts",
    "client/src/main.tsx",
    ".claude/hooks/*.js",
    "server/config/*.ts",
    "scripts/__fixtures__/*",
    "vite.config.ts",
    "drizzle.config.ts",
    "vitest.config.ts",
    "scripts/*.ts",
    "scripts/*.mjs",
    "scripts/gates/*.mjs",
    "scripts/migrations/*.ts",
    "server/scripts/*.ts"
  ],
  "project": [
    "server/**/*.ts",
    "client/src/**/*.ts",
    "client/src/**/*.tsx",
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    ".claude/hooks/**/*.js"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "**/node_modules/**",
    "dist/**",
    "migrations/**",
    "shared/derived/**",
    "server/db/schema/__types-check__/**",
    "server/types/**",
    "scripts/__fixtures__/**/*"
  ],
  "ignoreDependencies": [
    "@tiptap/pm",
    "@tiptap/react",
    "@tiptap/starter-kit",
    "@playwright/test",
    "depcheck",
    "jscpd",
    "madge",
    "@vitest/coverage-v8",
    "autoprefixer",
    "postcss",
    "tailwindcss",
    "@types/diff"
  ]
}
