  "project": [
    "server/**/*.ts",
    "client/src/**/*.ts",
    "client/src/**/*.tsx",
    "shared/**/*.ts",
    "worker/src/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    ".claude/hooks/**/*.js"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "**/node_modules/**",
    "dist/**",
    "migrations/**",
    "shared/derived/**",
    "server/db/schema/__types-check__/**",
    "server/types/**",
    "scripts/__fixtures__/**/*"
  ],
  "ignoreDependencies": [
    "@tiptap/pm",
    "@tiptap/react",
    "@tiptap/starter-kit",
    "@playwright/test",
    "depcheck",
    "jscpd",
    "madge",
    "@vitest/coverage-v8",
    "autoprefixer",
    "postcss",
    "tailwindcss",
    "@types/diff"
  ]
}
