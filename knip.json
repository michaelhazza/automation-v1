{
  "$schema": "node_modules/knip/schema.json",
  "entry": [
    "server/index.ts",
    "client/src/main.tsx",
    "worker/src/index.ts",
    ".claude/hooks/*.js",
    "server/config/*.ts",
    "scripts/__fixtures__/*",
    "vite.config.ts",
    "drizzle.config.ts",
    "vitest.config.ts",
    "scripts/*.ts",
    "scripts/*.mjs",
    "scripts/gates/*.mjs",
    "scripts/migrations/*.ts",
    "server/scripts/*.ts",
    "scripts/lib/check-handler-registry-verdicts.mjs",
