    "server/workflows/*.workflow.ts",
    "server/db/rlsExclusions.ts",
    "server/lib/canonicaliseUrl.ts",
    "server/tools/meta/types.ts",
    "shared/types/capabilityMap.ts",
    "shared/types/errorCodes.ts",
    "shared/types/slackAction.ts",
    "shared/types/systemIncidentEvent.ts",
    "client/src/hooks/useAgentPresence.ts",
    "client/src/hooks/useWorkspacePresence.ts",
    "client/src/hooks/useAgentRecommendations.ts",
    "client/src/hooks/useAgentRecommendationsTotal.ts",
    "client/src/lib/agentPresenceStream.ts",
    "client/src/components/recommendations/AgentRecommendationsList.tsx",
    "client/src/components/operator/OperatorBudgetExceededModal.tsx",
    "client/src/components/operator/OperatorConcurrencyLimitModal.tsx",
    "client/src/components/operator/OperatorUnavailableModal.tsx",
    "client/src/components/rules/RuleConflictResolutionDialog.tsx",
    "client/src/components/system-incidents/DiagnosisAnnotation.tsx",
    "client/src/components/system-incidents/DiagnosisFilterPill.tsx",
    "client/src/components/system-incidents/FeedbackWidget.tsx",
    "client/src/components/system-incidents/InvestigatePromptBlock.tsx",
    "client/src/components/dashboard/OperationalMetricsPlaceholder.tsx",
    "client/src/components/dashboard/QueueHealthSummary.tsx",
    "client/src/components/dashboard/WorkspaceFeatureCard.tsx",
    "client/src/pages/agents/AgentCreateScorecardSection.tsx",
    "client/src/pages/agents/AgentEditScorecardTab.tsx",
    "client/src/pages/govern/components/ConnectionTestButton.tsx",
    "client/src/pages/govern/components/DisclosureVersionBumpModal.tsx",
    "client/src/pages/SptOnboardingPage.tsx",
    "client/src/pages/skills/SkillCreatePage.tsx",
    "scripts/lib/systemMonitorSeed.ts",
    "server/services/agentTemplateService.ts",
    "server/services/trustCalibrationService.ts",
    "worker/src/browser/artifactValidator.ts",
    "worker/src/browser/captureStreamingVideo.ts",
    "worker/src/browser/contractEnforcedPage.ts",
    "worker/src/browser/executor.ts",
    "worker/src/browser/login.ts",
    "worker/src/browser/observe.ts",
    "worker/src/browser/playwrightContext.ts",
    "worker/src/lib/uploadArtifact.ts",
    "worker/src/persistence/integrationConnections.ts"
